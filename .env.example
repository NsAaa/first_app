# ─── Wallet ───────────────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY_BASE64=your_base64_encoded_private_key_here
WALLET_PUBLIC_KEY=your_public_key_here

# ─── Solana RPC ───────────────────────────────────────────────────────────────
# Default: public mainnet (rate-limited). Use a private RPC for better performance.
# Free options: https://app.helius.dev or https://app.quicknode.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ─── Telegram Alerts ─────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Trading Mode ─────────────────────────────────────────────────────────────
# DRY_RUN=true  → simulate trades, no real execution (safe for testing)
# DRY_RUN=false → LIVE TRADING (real money, use with caution!)
DRY_RUN=true

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
