{
  "name": "solana-bot",
  "version": "1.0.0",
  "description": "Solana momentum trading bot with Jupiter execution",
  "main": "dist/bot.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "npm run build && node dist/bot.js",
    "dev": "ts-node --project tsconfig.json src/bot.ts",
    "watch": "tsc --project tsconfig.json --watch",
    "clean": "rm -rf dist"
  },
  "keywords": ["solana", "trading", "bot", "jupiter", "defi"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.4",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "uuid": "^11.0.5",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
